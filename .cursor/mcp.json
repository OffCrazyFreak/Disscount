{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "context7": {
      "command": "npx",
      "args": ["@upstash/context7-mcp@1.0.31"]
    },
    "supabase": {
      "url": "https://mcp.supabase.com/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["--registry", "https://registry.npmjs.org", "chrome-devtools-mcp@1.4.0"]
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp/disscount/disscount-frontend"
    }
  }
}
