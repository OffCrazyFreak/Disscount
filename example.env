# =============================================================================
# Docker Compose environment for the FULL local stack (db + backend + frontend).
# Copy this file to ".env" and fill in real values. URLs use Docker service
# names (db / backend / frontend) for in-network calls.
# =============================================================================

# ---- PostgreSQL (db service) ----
POSTGRES_DB=disscount
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# ---- Backend (Spring Boot) runtime ----
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/disscount
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change_me
# Backend validates better-auth JWTs: fetch JWKS over the Docker network (frontend service),
# but the issuer claim is the browser-facing URL — it MUST equal BETTER_AUTH_URL.
BETTER_AUTH_JWKS_URI=http://frontend:3000/api/auth/jwks
BETTER_AUTH_ISSUER=http://localhost:3000
# Backend Sentry project DSN (Settings -> Projects -> disscount-backend -> Client Keys)
SENTRY_DSN=
SENTRY_ENVIRONMENT=local

# ---- Frontend build args (NEXT_PUBLIC_*: baked into the browser bundle at build) ----
# Internal URL for server-side rewrites/SSR; the browser uses relative /api and ignores this.
NEXT_PUBLIC_API_URL=http://backend:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_website_id
NEXT_PUBLIC_ENABLE_REACT_SCAN=false
# Frontend Sentry project DSN (disscount-frontend) — public DSN, used at build + runtime
NEXT_PUBLIC_SENTRY_DSN=

# ---- Frontend runtime secrets (server-only; never baked into the bundle) ----
DATABASE_URL=postgresql://postgres:change_me@db:5432/disscount
BETTER_AUTH_SECRET=your_better_auth_secret
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_CLIENT_ID=your_facebook_app_id
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="Disscount <noreply@disscount.me>"
CIJENE_API_URL=https://api.cijene.dev
CIJENE_API_TOKEN=your_cijene_token

# ---- Sentry source-map upload (build-time, optional) ----
# Only used by CI/prod image builds to upload source maps; NOT used by the local build.
SENTRY_AUTH_TOKEN=
